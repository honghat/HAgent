# ============================================================
# HAgent — .env template
# Copy thành .env tại project root, điền giá trị thật.
# KHÔNG commit file .env (đã có trong .gitignore).
# ============================================================

# ── Backend: LLM API Keys ────────────────────────────────────
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Backend: Model overrides ─────────────────────────────────
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Pekpik Free API (https://github.com/alistaitsacle/free-llm-api-keys) ──
PEKPIK_API_KEY=
PEKPIK_MODEL=deepseek-chat
PEKPIK_BASE_URL=https://aiapiv2.pekpik.com/v1

# ── Backend: Local LLM Providers ─────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen3.5:4b
LM_STUDIO_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# ── Backend: Telegram Bots ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_HOME_CHANNEL_THREAD_ID=

# ── Backend: YouTube OAuth ───────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Backend: Google Drive OAuth ──────────────────────────────
GOOGLE_DRIVE_REFRESH_TOKEN=
# Tự tạo khi lưu OAuth credential mã hóa trong data/hagent.db
HAGENT_CREDENTIAL_KEY=

# ── Backend: Gateway ─────────────────────────────────────────
GATEWAY_ALLOW_ALL_USERS=true

# ── Frontend: Vite ───────────────────────────────────────────
VITE_API_URL=http://127.0.0.1:8004
VITE_WS_URL=ws://127.0.0.1:8004
VITE_JWT_SECRET=
VITE_MCP_ENABLED=true
VITE_CAMERA_STREAM_URL=http://100.69.50.64:8080/video

# ── Learn: Database ──────────────────────────────────────────
DATABASE_URL="file:../data/hagent.db"

# ── Remote: SSH ──────────────────────────────────────────────
SSH_PASSWORD=
SSH_REMOTE_HOST=100.69.50.64
SSH_REMOTE_USER=hatnguyen
SSH_REMOTE_PORT=22
HAGENT_STT_URL=http://127.0.0.1:9000/v1/audio/transcriptions
HAGENT_STT_HEALTH_URL=http://127.0.0.1:9000/health
HAGENT_SENSEVOICE_STT_URL=http://127.0.0.1:9000/v1/audio/transcriptions
HAGENT_SENSEVOICE_HEALTH_URL=http://127.0.0.1:9000/health
HAGENT_WHISPER_STT_URL=http://127.0.0.1:9001/v1/audio/transcriptions
HAGENT_WHISPER_HEALTH_URL=http://127.0.0.1:9001/health
HAGENT_STT_REMOTE_HOST=100.69.50.64
HAGENT_SENSEVOICE_REMOTE_PORT=9000
HAGENT_SENSEVOICE_LOCAL_PORT=9000
HAGENT_SENSEVOICE_REMOTE_START_CMD=cd ~/HAgent/stt && SENSEVOICE_PORT=9000 ./start.sh
HAGENT_SENSEVOICE_REMOTE_STOP_CMD=cd ~/HAgent/stt && ./whisper_off.sh
HAGENT_WHISPER_REMOTE_PORT=9001
HAGENT_WHISPER_LOCAL_PORT=9001
HAGENT_WHISPER_REMOTE_START_CMD=cd ~/HAgent/stt && mkdir -p logs && nohup setsid -f env WHISPER_PORT=9001 WHISPER_CPP_PORT=9101 WHISPER_BACKEND=faster-whisper FASTER_WHISPER_DEVICE=cuda FASTER_WHISPER_COMPUTE_TYPE=float16 FASTER_WHISPER_MODEL=small .venv/bin/python whisper_server.py > logs/whisper.log 2>&1 < /dev/null
HAGENT_STT_TIMEOUT=180
WHISPER_BACKEND=faster-whisper
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_MODEL=small
HAGENT_WHISPER_REMOTE_STOP_CMD=pkill -f 'whisper_server.py|whisper-server' || true
HAGENT_STT_SYNC_MODEL_BEFORE_START=1
HAGENT_STT_SYNC_SCRIPT=/Users/nguyenhat/HAgent/scripts/stt-remote-sync-model.sh
HAGENT_STT_LOCAL_DIR=/Users/nguyenhat/HAgent/stt
HAGENT_STT_REMOTE_DIR=~/HAgent/stt
HAGENT_STT_SYNC_WHISPER_CPP=1
HAGENT_STT_LOCAL_MODEL_DIR=/Users/nguyenhat/HAgent/stt/models
HAGENT_STT_REMOTE_MODEL_DIR=~/HAgent/stt/models
HAGENT_STT_LOCAL_WHISPER_MODEL_DIR=/Users/nguyenhat/HAgent/stt/whisper.cpp/models
HAGENT_STT_REMOTE_WHISPER_MODEL_DIR=~/HAgent/stt/whisper.cpp/models
HAGENT_PIPER_TTS_URL=http://127.0.0.1:5001
HAGENT_LUX_TTS_URL=http://127.0.0.1:8880
HAGENT_KOKORO_TTS_URL=http://127.0.0.1:8881
HAGENT_TTS_REMOTE_HOST=100.69.50.64
HAGENT_TTS_LOCAL_DIR=/Users/nguyenhat/HAgent/tts
HAGENT_TTS_REMOTE_DIR=~/HAgent/tts
HAGENT_TTS_SYNC_BEFORE_START=1
HAGENT_TTS_REMOTE_BOOTSTRAP=1
HAGENT_TTS_SYNC_SCRIPT=/Users/nguyenhat/HAgent/scripts/tts-remote-sync.sh
HAGENT_KOKORO_REMOTE_PORT=8881
HAGENT_KOKORO_LOCAL_PORT=8881
HAGENT_KOKORO_REMOTE_START_CMD=cd ~/HAgent/tts && mkdir -p logs kokoro && nohup setsid -f env KOKORO_PORT=8881 .venv/bin/python kokoro_server.py > logs/kokoro.log 2>&1 < /dev/null
HAGENT_KOKORO_REMOTE_STOP_CMD=pkill -f 'kokoro_server.py|kokoro.*server' || true
HAGENT_LUX_REMOTE_PORT=8880
HAGENT_LUX_LOCAL_PORT=8880
HAGENT_LUX_REMOTE_START_CMD=cd ~/HAgent/tts/LuxTTS && mkdir -p ../logs && nohup setsid -f env PYTHONPATH="$PWD:$PWD/zipvoice" .venv/bin/python server.py > ../logs/lux.log 2>&1 < /dev/null
HAGENT_LUX_REMOTE_STOP_CMD=pkill -f 'LuxTTS.*server.py|/server.py' || true

# ── Remote: Wake-on-LAN via hat-pi ───────────────────────────
WOL_VIA_PI=true
WOL_PI_HOST=100.124.52.107
WOL_PI_USER=pi
WOL_PI_SSH_PASSWORD=
WOL_MAC=9c:6b:00:17:93:7a
WOL_TARGET_IP=192.168.1.255
WOL_PORT=9
WOL_VERIFY_TIMEOUT=75
WOL_VERIFY_INTERVAL=3

# ── SearXNG ──────────────────────────────────────────────────
SEARXNG_URL=http://127.0.0.1:8888
