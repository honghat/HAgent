# pnpm config cho workspace HAgent
# - shamefully-hoist: cần thiết cho Next.js 16 (learn) và một số plugin Vite
# - strict-peer-dependencies: tắt để khỏi vỡ vì peer dep lỏng lẻo
# - auto-install-peers: bật để tự cài peer deps thiếu
shamefully-hoist=true
strict-peer-dependencies=false
auto-install-peers=true
