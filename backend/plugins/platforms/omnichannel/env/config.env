# Omnichannel Hub Configuration
OMNICHANNEL_ENABLED=true
OMNICHANNEL_API_PORT=8080
OMNICHANNEL_HOST=127.0.0.1
OMNICHANNEL_API_TOKEN=""  # Required for protected endpoints. Set in runtime secret file.

# Zalo (REQUIRED for multi-platform)
ZALO_COOKIE_STRING=""  # Set after QR scan or browser cookie extraction
ZALO_QR_ENABLED=true   # Enable QR code login mode
ZALO_BOT_UID=""        # Auto-detect if empty

# Facebook Messenger (OPTIONAL)
FACEBOOK_COOKIE_STRING=""  # Empty for now, add when needed
FACEBOOK_HEADLESS=false

# Session storage
OMNICHANNEL_SESSION_FILE=${HAGENT_HOME}/omnichannel_sessions.json
OMNICHANNEL_SECRET_FILE=${HAGENT_HOME}/plugins/platforms/omnichannel/config.env
