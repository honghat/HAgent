{
  "manifest_version": 3,
  "name": "HAgent Cookie Sync",
  "version": "1.0",
  "description": "Đồng bộ nhanh Cookie Facebook về HAgent.",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.zalo.me/*",
    "http://127.0.0.1:8010/*",
    "http://localhost:8010/*",
    "http://localhost:3004/*",
    "http://127.0.0.1:3004/*",
    "https://hatai.io.vn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
